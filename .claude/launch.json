{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "5500", "."],
      "port": 5500
    },
    {
      "name": "backend-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/server.js"],
      "port": 3001
    },
    {
      "name": "streamlit-app",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "streamlit_app/app.py", "--server.headless", "true", "--server.port", "8501"],
      "port": 8501
    }
  ]
}
